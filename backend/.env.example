# MongoDB Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net
MONGO_DBNAME=stutterDB

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here

# Google OAuth Configuration (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Email Service Configuration (Gmail SMTP)
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Model Configuration
MODEL_PATH=./models/model_epoch10.pth
DEVICE=cpu

# Frontend URL (set this to your Render frontend URL for CORS)
# Example: https://fluencyassist-frontend.onrender.com
FRONTEND_URL=http://localhost:3000
